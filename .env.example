# ============================================================================
# Transcription API Environment Variables
# ============================================================================
# Copy this file to .env and configure values for your environment.
# Documentation: https://github.com/shozibsayyed/volgatest
# ============================================================================

# API SETTINGS
# ============================================================================

# API service title displayed in OpenAPI documentation
API_TITLE=Transcription API

# API version number (semantic versioning)
API_VERSION=1.0.0

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# INFO is recommended for production; DEBUG for development
LOG_LEVEL=INFO


# WHISPER MODEL CONFIGURATION
# ============================================================================
# Whisper is an automatic speech recognition (ASR) system trained on 680,000
# hours of multilingual and multitask supervised data collected from the web.
# See: https://github.com/openai/whisper

# Model size to use for transcription
# Options: tiny, base, small, medium, large
# - tiny:   ~39M parameters (fastest, least accurate)
# - base:   ~74M parameters (default, balanced)
# - small:  ~244M parameters (slower, more accurate)
# - medium: ~769M parameters (much slower, high accuracy)
# - large:  ~1.5B parameters (slowest, highest accuracy)
MODEL_SIZE=base

# Compute device for model inference
# Options: cpu, cuda
# - cpu:  Works on all systems, slower (recommended for development)
# - cuda: GPU acceleration (requires NVIDIA GPU with CUDA support)
DEVICE=cpu

# Data type for model quantization/precision
# Options: int8, float16, float32
# - int8:    Most memory efficient, slight accuracy loss, faster
# - float16: Good balance, requires GPU, reduced memory
# - float32: Full precision, highest accuracy, most memory required
COMPUTE_TYPE=int8


# FILE UPLOAD CONFIGURATION
# ============================================================================

# Maximum allowed file size in bytes
# Default: 104857600 (100 MB)
# Adjust based on your server resources and use case
MAX_FILE_SIZE=104857600

# Supported audio formats are automatically configured:
# Extensions: .wav, .mp3, .flac, .ogg, .webm, .mp4, .m4a
# MIME types: audio/wav, audio/x-wav, audio/mpeg, audio/mp3, audio/flac,
#             audio/ogg, audio/webm, audio/mp4, audio/x-m4a


# DEPLOYMENT NOTES
# ============================================================================

# GPU Setup (for CUDA):
#   1. Install NVIDIA CUDA Toolkit (https://developer.nvidia.com/cuda-downloads)
#   2. Install cuDNN (https://developer.nvidia.com/cudnn)
#   3. Install faster-whisper with GPU support:
#      pip install faster-whisper[cuda]
#   4. Set DEVICE=cuda and COMPUTE_TYPE=float16

# Memory Requirements:
#   - tiny/base + cpu + int8:   ~1-2 GB RAM
#   - small + cpu + int8:       ~2-4 GB RAM
#   - medium + cpu + int8:      ~4-6 GB RAM
#   - large + cpu + int8:       ~6-10 GB RAM
#   - With GPU (float16):       ~6-8 GB VRAM

# Performance Tips:
#   1. Use smaller models (tiny/base) for real-time transcription
#   2. Use larger models (medium/large) for batch processing with higher accuracy
#   3. GPU acceleration (CUDA) significantly improves performance
#   4. int8 quantization reduces memory usage with minimal accuracy loss
#   5. Adjust MAX_FILE_SIZE based on your server capabilities
